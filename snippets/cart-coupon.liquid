{%- if settings.enable_coupon_input -%}
  <div class="cart-coupon-wrapper" id="cart-coupon-wrapper">
    <div class="cart-coupon-container">
      <div class="field">
        <input
          type="text"
          id="cart-coupon-input"
          class="field__input"
          placeholder="{{ settings.coupon_placeholder }}"
          aria-label="{{ settings.coupon_placeholder }}"
        >
        <label class="field__label" for="cart-coupon-input">{{ settings.coupon_placeholder }}</label>
      </div>
      <button type="button" id="cart-coupon-apply" class="button button--secondary">
        Apply
      </button>
    </div>
    <div id="cart-coupon-message" class="cart-coupon-message"></div>
  </div>

  <style>
    .cart-coupon-wrapper {
      margin: 2rem 0;
      max-width: 35rem;
      margin-left: auto;
    }
    .cart-coupon-container {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .cart-coupon-container .field {
      flex: 1;
      margin: 0;
    }
    .cart-coupon-container .button {
      min-width: 10rem;
      margin: 0;
    }
    .cart-coupon-message {
      margin-top: 0.5rem;
      font-size: 1.3rem;
      min-height: 1.5rem;
    }
    .cart-coupon-message.error {
      color: #d0021b;
    }
    .cart-coupon-message.success {
      color: #28a745;
    }
    
    @media screen and (max-width: 749px) {
      .cart-coupon-wrapper {
        margin-left: 0;
        max-width: 100%;
      }
    }
  </style>
  
  <script src="{{ 'cart-coupon.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
